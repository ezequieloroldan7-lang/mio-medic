# ── MIO MEDIC — variables de entorno ─────────────────────────
# Copiar este archivo como .env y completar los valores.
# NUNCA subir el .env real a git.

# ── Seguridad (OBLIGATORIO en producción) ────────────────────
# Clave para firmar los JWT de sesión. Si no se define, la app genera una
# persistente en backend/.secret_key. En Render, usar generateValue: true.
# Generar con:   python -c "import secrets; print(secrets.token_urlsafe(48))"
SECRET_KEY=

# Contraseña inicial del usuario admin "mioturnos" (solo primer arranque).
# El usuario DEBE cambiarla en el primer login. Si se deja vacío, se genera
# una aleatoria y se imprime UNA VEZ en los logs.
INITIAL_ADMIN_PASSWORD=

# Contraseña inicial para los usuarios profesionales auto-creados (mismo
# comportamiento que INITIAL_ADMIN_PASSWORD).
INITIAL_USER_PASSWORD=

# Duración de la sesión (JWT) en horas. Default: 4.
ACCESS_TOKEN_EXPIRE_HOURS=4

# Largo mínimo de contraseña exigido al cambiarla. Default: 8.
MIN_PASSWORD_LEN=8

# ── Base de datos ────────────────────────────────────────────
# Fallback: sqlite en backend/miomedic.db
# Para Postgres: postgresql+psycopg://user:pass@host:5432/miomedic
DATABASE_URL=sqlite:///./miomedic.db

# Nivel de log
LOG_LEVEL=INFO

# Días de retención del backup automático del SQLite. Default: 14.
# El backup corre cada día a las 03:00 y guarda en backend/backups/.
# Ignorado si DATABASE_URL no apunta a SQLite.
BACKUP_RETENTION_DAYS=14

# ── CORS ─────────────────────────────────────────────────────
# Lista blanca separada por comas. Vacío = solo same-origin (caso típico:
# frontend servido por la misma app). "*" solo se acepta explícitamente y
# nunca se recomienda en producción.
CORS_ORIGINS=

# ── WhatsApp Cloud API (Meta) ────────────────────────────────
# https://developers.facebook.com/docs/whatsapp/cloud-api
#
# 1) Crear una app tipo "Business" en https://developers.facebook.com/apps
# 2) Agregar el producto "WhatsApp" → vas a obtener un Phone Number ID
# 3) Generar un System User Access Token permanente en Business Settings
# 4) Crear y enviar a aprobación una plantilla de recordatorio en:
#    Meta Business Suite → WhatsApp → Plantillas de mensaje
#    (template name debe coincidir con WHATSAPP_TEMPLATE_NAME)
#
# La plantilla debe tener 4 variables BODY:
#   {{1}} = nombre paciente
#   {{2}} = fecha y hora
#   {{3}} = profesional
#   {{4}} = especialidad

WHATSAPP_ACCESS_TOKEN=EAAxxxxxxxxxxxxxxxxxxxxxxxxx
WHATSAPP_PHONE_NUMBER_ID=1234567890
WHATSAPP_TEMPLATE_NAME=recordatorio_turno
WHATSAPP_TEMPLATE_AGENDADO=turno_agendado
WHATSAPP_TEMPLATE_LANG=es_AR
WHATSAPP_API_VERSION=v21.0

# ── Google Calendar (Service Account) ────────────────────────
# https://console.cloud.google.com → APIs → Calendar API → habilitar
# Crear Service Account → descargar JSON → guardar en backend/
# Cada médico debe compartir su calendar con el email del service account
GOOGLE_CREDENTIALS_JSON=google-credentials.json
